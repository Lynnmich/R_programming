#Bar Plots
# Create barplots with the barplot(height) function
# height is a vector or matrix
# Bar Plots:basic
# Subset
x <- VADeaths[1:3, "Rural Male"]
x
VADeaths
VADeaths
## 50-54 55-59 60-64
## 11.7 18.1 26.9
# Bar plot of one variable
barplot(x)
# Horizontal bar plot (adding the argument horiz = TRUE)
barplot(x, horiz = TRUE)
#Change group names: using argument names.arg = c("A", "B", "C")
barplot(x, names.arg = c("A", "B", "C"))
# Change color
# Change border and fill color using one single color
barplot(x, col = "white", border = "steelblue")
barplot(x, col = "white",
border = c("#999999", "#E69F00", "#56B4E9"))
barplot(x, col = "steelblue")
# Change fill color: multiple colors
barplot(x, col = c("#999999", "#E69F00", "#56B4E9"))
barplot(x, col = c("#999999", "#E69F00", "#56B4E9")
border = c("#999999", "#E69F00", "#56B4E9")
barplot(x, col = c("#999999", "#E69F00", "#56B4E9"),
border = c("#999999", "#E69F00", "#56B4E9")
)
barplot(x, col = c("#999999", "#E69F00", "#56B4E9"),
border = c("#999999", "#E69F00", "#56B4E9")
)
# Bar Plots
# Change main title and axis labels
# Change axis titles
# Change color (col = "gray") and remove frame
barplot(x, main = "Death Rates in
Virginia",  xlab = "Age", ylab = "Rate")
# Stacked bar plots
barplot(VADeaths, col = c("lightblue", "mistyrose", "lightcyan", "lavender",
"cornsilk"),    legend = rownames(VADeaths))
barplot(VADeaths, col = c("lightblue", "mistyrose", "lightcyan",
"lavender", "cornsilk"), legend = rownames(VADeaths), beside = TRUE)
